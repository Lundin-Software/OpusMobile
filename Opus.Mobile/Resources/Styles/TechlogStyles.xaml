<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <x:Double x:Key="Tl.FontXs">12</x:Double>
    <x:Double x:Key="Tl.FontSm">14</x:Double>
    <x:Double x:Key="Tl.FontMd">16</x:Double>

    <Color x:Key="Tl.PanelLight">#FFFFFF</Color>
    <Color x:Key="Tl.PanelDark">#1A1F26</Color>
    <Color x:Key="Tl.PanelInnerLight">#F4F6F8</Color>
    <Color x:Key="Tl.PanelInnerDark">#232932</Color>
    <Color x:Key="Tl.LineLight">#E6E8EC</Color>
    <Color x:Key="Tl.LineDark">#2C333D</Color>
    <Color x:Key="Tl.MutedLight">#6B7280</Color>
    <Color x:Key="Tl.MutedDark">#9AA3B2</Color>
    <Color x:Key="Tl.InfoFg">#2563EB</Color>

    <Style x:Key="Tl.Panel" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource Tl.PanelLight}, Dark={StaticResource Tl.PanelDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Light={StaticResource Tl.LineLight}, Dark={StaticResource Tl.LineDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="Tl.PanelInner" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource Tl.PanelInnerLight}, Dark={StaticResource Tl.PanelInnerDark}}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
        <Setter Property="Padding" Value="12,10" />
    </Style>
    
    <Style x:Key="Tl.ItemTitle" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource Tl.FontSm}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines" Value="1" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}" />
    </Style>

    <Style x:Key="Tl.ItemMeta" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource Tl.FontSm}" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource Tl.MutedLight}, Dark={StaticResource Tl.MutedDark}}" />
    </Style>

    <Style x:Key="Tl.ItemMetaStrong" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource Tl.FontSm}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}" />
    </Style>

    <Style x:Key="Tl.MetricLabel" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource Tl.FontXs}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource Tl.MutedLight}, Dark={StaticResource Tl.MutedDark}}" />
    </Style>

    <Style x:Key="Tl.SegmentTab" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Tl.PanelInnerLight}, Dark={StaticResource Tl.PanelInnerDark}}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style x:Key="Tl.SegmentTabLabel" TargetType="Label">
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}" />
    </Style>

</ResourceDictionary>